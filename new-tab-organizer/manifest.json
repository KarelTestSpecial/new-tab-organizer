{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "5.1",
  "description": "__MSG_extDesc__",
  "default_locale": "nl",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "notifications"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "panelA.html",
        "panelB.html",
        "panelC.html",
        "panelD.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "panelA.html"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}